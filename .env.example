QBITTORRENT_URL=http://qbittorrent:8080
QBITTORRENT_USERNAME=admin
QBITTORRENT_PASSWORD=change-me
WATCH_PATHS=/data
EXCLUDED_GLOBS=/data/logs/*,/data/orphaned-files/*,find_duplicates.sh,rar_extractor.sh,video_folders.log
DRY_RUN=true
POLL_INTERVAL_SECONDS=300
ORPHAN_GRACE_SECONDS=21600
MIN_FILE_AGE_SECONDS=1800
DELETE_EMPTY_DIRS=true
PROTECT_SINGLE_FILE_PARENT_DIRS=true
STATE_DB_PATH=/config/state.sqlite3
REPORT_PATH=/config/last-run.json
LOG_LEVEL=INFO

# Attempts per idempotent (GET/HEAD) request to qBittorrent/Plex/Radarr/Sonarr.
# 1 = no retry (default). Raise it (e.g. 3) so a transient 5xx or connection blip
# on a LAN call is retried with exponential backoff instead of failing the
# read-only report on the first hiccup. qBittorrent's login POST is never retried.
HTTP_MAX_ATTEMPTS=1

# RAR extraction (opt-in) — runs in every `scan`/`service` cycle (and the
# standalone `extract` subcommand). Detects and extracts RAR archives in the
# download path so Radarr/Sonarr can import scene releases, then protects the
# extracted media from the deletion pass. Off by default and honors DRY_RUN
# (dry-run reports would-extract and writes nothing). Linux-container only (needs
# the bundled `unar` binary). Set EXTRACT_OWNER to a numeric uid:gid
# (Unraid = 99:100) for a best-effort chown of extracted files; leave empty to
# skip. EXTRACT_PROTECT_SECONDS is how long extracted output stays undeletable
# after extraction (default 24h) so *arr can import before cleanup resumes.
EXTRACT_ENABLED=false
EXTRACT_TOOL=unar
EXTRACT_OWNER=
EXTRACT_MIN_AGE_SECONDS=300
EXTRACT_PROTECT_SECONDS=86400

# Plex duplicate report — consumed by the read-only `plex-duplicates` subcommand.
# Unused by the scan/service cleanup commands; leave PLEX_URL/PLEX_TOKEN empty if
# you don't run the duplicate report.
PLEX_URL=
PLEX_TOKEN=
PLEX_SECTIONS=
PLEX_TIMEOUT_SECONDS=30
PLEX_VERIFY_TLS=true
PLEX_DUPLICATE_REPORT_PATH=/config/plex-duplicates.json

# Optional Radarr/Sonarr tracking for the plex-duplicates report. Each *arr is
# enabled only when both its URL and API key are set; it annotates whether a
# duplicate copy is tracked (deleting it re-downloads) vs safe. Read-only.
RADARR_URL=
RADARR_API_KEY=
RADARR_TIMEOUT_SECONDS=30
RADARR_VERIFY_TLS=true
SONARR_URL=
SONARR_API_KEY=
SONARR_TIMEOUT_SECONDS=30
SONARR_VERIFY_TLS=true

# Web GUI for the Plex duplicate report. Run it standalone with the `web`
# subcommand, or set WEB_ENABLED=true to also serve it from the long-running
# `service` (one container that both cleans up and serves the report). It reads
# the on-disk PLEX_DUPLICATE_REPORT_PATH snapshot and renders a browsable page
# plus a JSON API at /api/report — it never runs a scan. Read-only by default;
# binds to all interfaces so a mapped container port is reachable; LAN-scoped like
# the rest of the stack.
WEB_ENABLED=false
WEB_BIND_ADDRESS=0.0.0.0
WEB_PORT=8080

# Web action layer (Phase 2): let an operator delete redundant copies from the
# browser. This is the first outside-triggered deletion of *library* media, so it
# is fail-closed. Off by default; even when enabled, WEB_ACTIONS_DRY_RUN reports
# what would be deleted and touches nothing until you set it false. The browser
# reclaim is two-step (a confirmation page previews exactly what would be deleted
# before anything is removed). Every reclaim must present WEB_ACTION_TOKEN — via the
# X-Action-Token header for the JSON API, or pasted once in the browser to set a
# one-hour HttpOnly/SameSite unlock cookie (so the confirm submit is not re-pasted).
# Enabling actions without a token refuses every request. WEB_MEDIA_PATH_MAP maps
# Plex-reported paths to this container's mounts (comma-separated
# plex_prefix:container_prefix pairs) so a filesystem delete of an *untracked* copy
# can find the file; an unmapped path is refused. Tracked copies are deleted via
# Radarr/Sonarr (so they don't re-download) and need no path map.
WEB_ENABLE_ACTIONS=false
WEB_ACTIONS_DRY_RUN=true
WEB_ACTION_TOKEN=
WEB_MEDIA_PATH_MAP=

# CSRF/origin hardening for a non-loopback bind. On the default loopback bind the
# behavior is unchanged; when WEB_BIND_ADDRESS is not loopback (e.g. 0.0.0.0), a
# browser reclaim FORM must present a same-origin Origin (or Referer) — a cross-site
# form POST is refused even if it omits Origin. The JSON API stays token-only when
# it sends no Origin (so curl keeps working). Behind a TLS-terminating reverse proxy
# the server sees plain HTTP and cannot trust the client Host to infer the external
# scheme, so set WEB_ALLOWED_ORIGINS to the external origin(s) the browser sends —
# a comma-separated list of full origins, e.g. https://media.example.com. Leave
# empty for a direct LAN bind (the same-origin-vs-Host check is used instead).
WEB_ALLOWED_ORIGINS=

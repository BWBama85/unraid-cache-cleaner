QBITTORRENT_URL=http://qbittorrent:8080
QBITTORRENT_USERNAME=admin
QBITTORRENT_PASSWORD=change-me
WATCH_PATHS=/data
EXCLUDED_GLOBS=/data/logs/*,/data/orphaned-files/*,find_duplicates.sh,rar_extractor.sh,video_folders.log
DRY_RUN=true
POLL_INTERVAL_SECONDS=300
ORPHAN_GRACE_SECONDS=21600
MIN_FILE_AGE_SECONDS=1800
DELETE_EMPTY_DIRS=true
PROTECT_SINGLE_FILE_PARENT_DIRS=true
STATE_DB_PATH=/config/state.sqlite3
REPORT_PATH=/config/last-run.json
LOG_LEVEL=INFO

# Attempts per idempotent (GET/HEAD) request to qBittorrent/Plex/Radarr/Sonarr.
# 1 = no retry (default). Raise it (e.g. 3) so a transient 5xx or connection blip
# on a LAN call is retried with exponential backoff instead of failing the
# read-only report on the first hiccup. qBittorrent's login POST is never retried.
HTTP_MAX_ATTEMPTS=1

# RAR extraction (opt-in) — runs in every `scan`/`service` cycle (and the
# standalone `extract` subcommand). Detects and extracts RAR archives in the
# download path so Radarr/Sonarr can import scene releases, then protects the
# extracted media from the deletion pass. Off by default and honors DRY_RUN
# (dry-run reports would-extract and writes nothing). Linux-container only (needs
# the bundled `unar` binary). Set EXTRACT_OWNER to a numeric uid:gid
# (Unraid = 99:100) for a best-effort chown of extracted files; leave empty to
# skip. EXTRACT_PROTECT_SECONDS is how long extracted output stays undeletable
# after extraction (default 24h) so *arr can import before cleanup resumes.
EXTRACT_ENABLED=false
EXTRACT_TOOL=unar
EXTRACT_OWNER=
EXTRACT_MIN_AGE_SECONDS=300
EXTRACT_PROTECT_SECONDS=86400

# Plex duplicate report — consumed by the read-only `plex-duplicates` subcommand.
# Unused by the scan/service cleanup commands; leave PLEX_URL/PLEX_TOKEN empty if
# you don't run the duplicate report.
PLEX_URL=
PLEX_TOKEN=
PLEX_SECTIONS=
PLEX_TIMEOUT_SECONDS=30
PLEX_VERIFY_TLS=true
PLEX_DUPLICATE_REPORT_PATH=/config/plex-duplicates.json

# Optional Radarr/Sonarr tracking for the plex-duplicates report. Each *arr is
# enabled only when both its URL and API key are set; it annotates whether a
# duplicate copy is tracked (deleting it re-downloads) vs safe. Read-only.
RADARR_URL=
RADARR_API_KEY=
RADARR_TIMEOUT_SECONDS=30
RADARR_VERIFY_TLS=true
SONARR_URL=
SONARR_API_KEY=
SONARR_TIMEOUT_SECONDS=30
SONARR_VERIFY_TLS=true
